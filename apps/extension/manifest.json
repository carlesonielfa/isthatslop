{
  "manifest_version": 3,
  "name": "IsThatSlop",
  "version": "0.1.0",
  "description": "Alerts you to AI-flagged content sources",
  "background": { "service_worker": "src/background.ts" },
  "permissions": ["alarms", "storage", "unlimitedStorage"],
  "host_permissions": ["https://isthatslop.com/*"]
}
